# Neon Postgres (Free tier - works with Vercel Hobby)
POSTGRES_URL="your-neon-connection-string"

# Scraping secret (for protecting the /api/scrape endpoint)
SCRAPE_SECRET="soiree-scrape-secret-2024"

# Instagram API (auto-posting weekly carousel via Instagram Login)
# Token: exchange short-lived token at graph.instagram.com/access_token
# User ID: from GET /me?fields=id in Graph API Explorer
INSTAGRAM_ACCESS_TOKEN="your-long-lived-access-token"
INSTAGRAM_USER_ID="your-ig-business-account-id"

# Vercel Blob (auto-set when you create a Blob store in Vercel dashboard)
BLOB_READ_WRITE_TOKEN="auto-set-by-vercel"
