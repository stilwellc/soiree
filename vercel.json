{
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    },
    "api/instagram-post.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/instagram-post",
      "schedule": "0 17 * * 2"
    }
  ],
  "rewrites": [
    { "source": "/(all|today|week|favorites|about|social|pins)", "destination": "/index.html" }
  ]
}
